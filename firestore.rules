rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Rides — any authenticated user can read; all writes go through
    // Cloud Functions (Admin SDK bypasses rules)
    match /rides/{rideId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Users — each user reads and writes their own profile.
    // completeOnboarding / offerRide write via Admin SDK so rules don't apply.
    match /users/{userId} {
      allow read:  if isOwner(userId);
      allow write: if isOwner(userId);

      match /private/{doc} {
        allow read, write: if isOwner(userId);
      }
    }

    // Stops — seeded via Admin SDK; read-only for authenticated clients
    match /stops/{stopId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Cancellations — users can read their own records only
    match /cancellations/{cancellationId} {
      allow read:  if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
  }
}
